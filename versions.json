{
  "registry": "ghcr.io/getbrik",
  "tools": {
    "yq": "v4.53.2",
    "jq": "1.8.1",
    "jv": "v6.0.2"
  },
  "deploy_tools": {
    "helm": "v4.1.4",
    "kubectl": "v1.36.0",
    "argocd": "v3.3.6"
  },
  "security_tools": {
    "semgrep": "1.161.0",
    "osv_scanner": "2.3.5",
    "grype": "0.111.1",
    "syft": "1.43.0",
    "checkov": "3.2.525",
    "hadolint": "2.14.0",
    "license_finder": "7.2.1",
    "scancode_toolkit": "32.5.0",
    "gitleaks": "8.30.1",
    "trufflehog": "3.95.2",
    "dockle": "0.4.15"
  },
  "stacks": {
    "base": {
      "versions": ["3.23"],
      "image_template": "alpine:${VERSION}",
      "verify_cmd": "bash --version"
    },
    "node": {
      "versions": ["22", "24"],
      "image_template": "node:${VERSION}-slim",
      "verify_cmd": "node --version && npm --version"
    },
    "python": {
      "versions": ["3.13", "3.14"],
      "image_template": "python:${VERSION}-slim",
      "verify_cmd": "python3 --version && pip --version"
    },
    "java": {
      "versions": ["21", "25"],
      "image_template": "eclipse-temurin:${VERSION}-jdk-jammy",
      "extra_packages": ["maven"],
      "verify_cmd": "java --version && mvn --version"
    },
    "rust": {
      "versions": ["1"],
      "image_template": "rust:${VERSION}-slim-bookworm",
      "verify_cmd": "rustc --version && cargo --version && cargo nextest --version && cargo llvm-cov --version"
    },
    "dotnet": {
      "versions": ["9.0", "10.0"],
      "image_template": "mcr.microsoft.com/dotnet/sdk:${VERSION}",
      "verify_cmd": "dotnet --version"
    },
    "analysis": {
      "versions": ["1"],
      "image_template": "alpine:3.23",
      "verify_cmd": "semgrep --version && checkov --version && license_finder version && scancode --version"
    },
    "scanner": {
      "versions": ["1"],
      "image_template": "alpine:3.23",
      "verify_cmd": "grype version && syft version && osv-scanner --version && hadolint --version && gitleaks version && trufflehog --version && dockle --version"
    },
    "deploy": {
      "versions": ["1"],
      "image_template": "ghcr.io/getbrik/brik-runner-base:latest",
      "verify_cmd": "helm version --short && kubectl version --client && argocd version --client"
    }
  }
}
