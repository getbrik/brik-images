    "quality": {
      "versions": ["1"],
      "image_template": "alpine:3.23",
      "verify_cmd": "semgrep --version && osv-scanner --version && grype version && syft version && checkov --version && hadolint --version && license_finder version && scancode --version"
    },
    "security": {
      "versions": ["1"],
      "image_template": "alpine:3.23",
      "verify_cmd": "gitleaks version && trufflehog --version && grype version && syft version && osv-scanner --version && dockle --version"
